# Optional live refresh configuration (local/dev only)
# Do not commit real credentials.

# JSON snapshot mode (existing workflow)
LIVE_DEPARTURES_SOURCE=https://example.com/api/departures
LIVE_ALERTS_SOURCE=https://example.com/api/alerts

# GTFS-RT mode (protobuf or JSON feed format)
GTFSRT_TRIP_UPDATES_SOURCE=https://example.com/gtfsrt/trip-updates
GTFSRT_SERVICE_ALERTS_SOURCE=https://example.com/gtfsrt/service-alerts
GTFSRT_TRIP_UPDATES_FORMAT=protobuf
GTFSRT_SERVICE_ALERTS_FORMAT=protobuf

# Optional GTFS static CSV sources used for ID/headsign enrichment
GTFS_STATIC_STOPS_SOURCE=
GTFS_STATIC_ROUTES_SOURCE=
GTFS_STATIC_TRIPS_SOURCE=

# Optional explicit ID map source (JSON)
GTFS_ID_MAP_SOURCE=

# Optional auth headers in Header-Name: value format
LIVE_HEADER_1=Authorization: Bearer replace_me
LIVE_HEADER_2=
LIVE_HEADER_3=
LIVE_HEADER_4=

# Optional timeout in milliseconds for fetch scripts
LIVE_FETCH_TIMEOUT_MS=20000
