{
  "name": "coastpulse-transit",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial static-first Gold Coast transit MVP for GitHub Pages.",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 4173",
    "validate:data": "node ./scripts/validate-data.mjs",
    "build:gtfs": "node ./scripts/transform-gtfs.mjs --input ./raw/gtfs --output ./data",
    "build:cap:web": "node ./scripts/build-capacitor-web.mjs",
    "cap:copy": "npm run build:cap:web && npx cap copy",
    "cap:sync": "npm run build:cap:web && npx cap sync",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "fetch:live": "node ./scripts/fetch-live-sources.mjs --out-raw-dir ./raw/live",
    "merge:live": "node ./scripts/merge-live-feeds.mjs --departures ./raw/live/departures.json --alerts ./raw/live/alerts.json --out ./data",
    "refresh:live": "npm run fetch:live && npm run merge:live && npm run validate:data",
    "fetch:gtfsrt": "node ./scripts/fetch-gtfsrt-sources.mjs --out-raw-dir ./raw/live",
    "build:live:gtfsrt": "node ./scripts/build-live-from-gtfsrt.mjs --trip-updates ./raw/live/trip-updates.pb --service-alerts ./raw/live/service-alerts.pb --out ./data",
    "refresh:live:gtfsrt": "npm run fetch:gtfsrt && npm run build:live:gtfsrt && npm run validate:data"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "gtfs-realtime-bindings": "^1.1.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
